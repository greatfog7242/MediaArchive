# ─── Secrets ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Node ─────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Next.js ──────────────────────────────────────────────────────
apps/web/.next/
apps/web/out/
apps/web/.env.local

# ─── Prisma ───────────────────────────────────────────────────────
