apps/web/node_modules/.prisma/

# ─── Build outputs ────────────────────────────────────────────────
apps/web/build/
dist/

# ─── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo

# ─── OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Docker ───────────────────────────────────────────────────────
# Keep: docker-compose.yml, Dockerfiles, docker/ configs
# Docker volumes are managed by Docker itself

# ─── IDE ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Temp / Logs ─────────────────────────────────────────────────
build-log.txt
temp.txt
cookies.txt
