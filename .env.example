# ─── Database ─────────────────────────────────────────────────────
POSTGRES_USER=mediaarchive
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=mediaarchive_db
DATABASE_URL=postgresql://mediaarchive:changeme_secure_password@postgres:5432/mediaarchive_db

# ─── Auth.js v5 ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme_replace_with_32_char_random_string
NEXTAUTH_URL=http://localhost:3000

# ─── Typesense ─────────────────────────────────────────────────────
TYPESENSE_API_KEY=changeme_typesense_admin_key
# Generated automatically by scripts/init-typesense.ts on first docker compose up
TYPESENSE_SEARCH_ONLY_KEY=changeme_search_only_key_generated_at_startup

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379

# ─── Public env vars (safe for browser bundle) ─────────────────────
NEXT_PUBLIC_TYPESENSE_HOST=localhost
NEXT_PUBLIC_TYPESENSE_PORT=8108
NEXT_PUBLIC_TYPESENSE_SEARCH_ONLY_KEY=changeme_search_only_key_generated_at_startup
